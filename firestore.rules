rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTask(data) {
      return data.keys().hasAll(['title', 'completed', 'priority', 'userId', 'createdAt']) &&
             hasOnlyAllowedFields(['title', 'completed', 'priority', 'userId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
             data.completed is bool &&
             data.priority in ['high', 'normal'] &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content']) &&
             hasOnlyAllowedFields(['role', 'content', 'imageUrl', 'videoUrl', 'audioData', 'createdAt']) &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 50000 &&
             (!('imageUrl' in data) || isValidString('imageUrl', 2000)) &&
             (!('videoUrl' in data) || isValidString('videoUrl', 2000)) &&
             (!('audioData' in data) || isValidString('audioData', 1000000)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTask(request.resource.data);
        allow update: if isOwner(userId) && isValidTask(request.resource.data) && 
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
      
      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(request.resource.data);
        allow update: if isOwner(userId) && isValidMessage(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
